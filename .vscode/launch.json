{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Argo CD Toolkit",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extensions"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "stopOnEntry": false,
      "timeout": 30000,
      "preLaunchTask": "npm: compile"
    }
  ]
}
